.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   It makes pyenv switch to the local version automatically.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, keeping Pipfile.lock
#   will cause dependency mismatch.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be gitignored or not.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be gitignored or not.
# pdm.lock
#   pdm persistent configuration
.pdm-python.path
.pdm-build/

# PEP 582; modern local dependency wheel
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath vars
*.sage.py

